# vim: filetype=i3
# File originally by Luke Smith <https://lukesmith.xyz>
# #---Basic Definitions---# #
for_window [class="^.*"] border pixel 2
gaps inner 5
gaps outer 10
gaps top 45

# #---Starting External Scripts---# #
exec --no-startup-id /usr/lib/geoclue-2.0/demos/agent
exec --no-startup-id easyeffects --gapplication-service
exec --no-startup-id dunst

# Requires ~/.local/bin to be in path and scripts to be executable.
exec --no-startup-id remaps
exec --no-startup-id unclutter

include ~/.config/i3/i3-specific-startups.conf
include ~/.config/i3/i3-specific-binds.conf

set_from_resource $fg i3wm.color4 #f0f0f0
set_from_resource $bg i3wm.color0 #f0f0f0
set_from_resource $ac i3wm.color3 #f0f0f0
set_from_resource $fc i3wm.color6 #f0f0f0
set_from_resource $fs i3wm.color4 #f0f0f0
set_from_resource $ug i3wm.color2 #f0f0f0

include ~/.config/i3/binds.conf

# Floating entries
for_window [class="Pinentry"] sticky enable
for_window [class="sent"] border pixel 0px
for_window [window_role="GtkFileChooserDialog"] resize set 800 600
for_window [window_role="GtkFileChooserDialog"] move position center
for_window [title="Default - Wine desktop"] floating enable
